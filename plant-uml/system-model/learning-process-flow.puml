@startuml
!pragma useVerticalIf on
skinparam maxMessageSize 150
skinparam wrapWidth 200

skinparam swimlane {
    BorderColor #757575
    BorderThickness 2
    TitleBackgroundColor #E3F2FD
    TitleFontColor #1565C0
    TitleFontSize 14
    TitleFontStyle bold
}

skinparam activity {
    BackgroundColor #FAFAFA
    BorderColor #424242
    FontName sans-serif
    DiamondBackgroundColor #FFF3E0
    DiamondBorderColor #EF6C00
}

|Người học (User)|
start
:Truy cập bài học & Chọn Mô hình 3D\n(Cyclotron, Loa điện động...);

|Giao diện WebGL (Frontend)|
:Tải không gian 3D (Three.js) & Nội dung lý thuyết;

|Người học (User)|
:Quan sát hiện tượng & Trực tiếp tinh chỉnh tham số 3D\n(vd: tần số, điện áp);
:Đặt câu hỏi truy vấn cho PhysicMUT-bot\n(vd: "Tại sao quỹ đạo thay đổi ở 50MHz?");

|Giao diện WebGL (Frontend)|
:Chụp trạng thái mô phỏng hiện tại\n(Snapshot & Parameters);
:Gửi Request (User Query + 3D Snapshot) tới API;

|AI Backend (FastAPI)|
:Truy xuất ngữ cảnh vật lý từ Sách giáo khoa\n(RAG - ChromaDB);
:LLM đối chiếu Snapshot với kiến thức gốc\n(Semantic Analysis);

if (Cần thay đổi thông số 3D để minh họa?) then (Có)
    :Sinh Phản hồi văn bản + Danh sách Lệnh\n(vd: **set_simulation_parameter**,\n**highlight_parameter**) ;
else (Không)
    :Sinh Phản hồi văn bản giải thích thông thường;
endif

:Trả về JSON Response cho máy khách;

|Giao diện WebGL (Frontend)|
:Hiển thị câu trả lời phân tích của AI\n(Chat Interface);

if (Response chứa mảng **toolCalls**?) then (Có)
    :Duyệt và thực thi **executeBotToolCalls()**;
    :Render lại hiệu ứng/tham số mới trên Canvas 3D\n(vd: Cập nhật biến, tạo hiệu ứng glow);
else (Không)
    :Duy trì trạng thái 3D hiện tại;
endif

|Người học (User)|
:Quan sát sự thay đổi trực quan trên mô hình 3D\n(Hiểu sâu nguyên lý);
:Đánh giá, làm bài tập & Hệ thống lưu tiến trình;
stop
@enduml