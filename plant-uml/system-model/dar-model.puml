@startuml
' Tùy chỉnh đường nét và font chữ chuẩn UML Distilled
skinparam defaultFontName sans-serif
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 40

' Bảng màu chuyên nghiệp theo phong cách HBR / Doanh nghiệp
skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontColor #212121
    FontSize 13
}
skinparam partition {
    BorderColor #757575
    BackgroundColor #FAFAFA
    FontColor #212121
    FontStyle bold
    FontSize 14
}
skinparam ActivityDiamond {
    BackgroundColor #FFF3E0
    BorderColor #EF6C00
    FontColor #212121
    FontStyle bold
}
skinparam ArrowColor #424242

title Chu trình Khép kín Display-Action-Response (DAR)

start

repeat
    partition "Tầng Máy khách (Client / Frontend)" {
        :**1. Display (Hiển thị)**\nHệ thống kết xuất giao diện Chat và môi trường WebGL 3D;
        
        #E8F5E9:**2. Action (Hành động)**\nNgười học nhập câu hỏi hoặc thao tác trực tiếp trên mô phỏng;
    }

    partition "Tầng Trí tuệ nhân tạo (AI Bot Engine)" {
        switch (**3. Response (Phản hồi)**\nPhân tích ý định & Quyết định cấp độ xử lý)
        
        case ( Cấp độ 1:\nTruy vấn Ngữ nghĩa )
            :**RAG Query**\nTruy xuất Vector DB (ChromaDB)\nvà sinh văn bản giải thích;
            
        case ( Cấp độ 2:\nỦy quyền Điều khiển )
            :**Tool Execution**\nLLM sinh JSON Tool Calls để can thiệp 3D\n(VD: Tăng tần số, đổi điện áp);
            
        case ( Cấp độ 3:\nPhân tích Trực quan )
            :**Snapshot Analysis**\nChụp trạng thái tham số 3D hiện tại,\nLLM đối chiếu & sinh hiệu ứng Highlight;
        endswitch
    }
    
    partition "Tầng Máy khách (Client / Frontend)" {
        :**Thực thi Phản hồi (Apply Response)**\nCập nhật UI Chat & Bóc tách Tool Calls\nđể đồng bộ hóa State render cho Three.js;
    }

' Vòng lặp hội thoại đa lượt
repeat while (Hội thoại đa lượt tiếp diễn?) is (Tiếp tục tương tác)
-> Kết thúc bài học;

stop
@enduml
