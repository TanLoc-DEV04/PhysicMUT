@startuml
!pragma useVerticalIf on
skinparam maxMessageSize 150
skinparam wrapWidth 200

skinparam swimlane {
    BorderColor #757575
    BorderThickness 2
    TitleBackgroundColor #E3F2FD
    TitleFontColor #1565C0
    TitleFontSize 14
    TitleFontStyle bold
}

skinparam activity {
    BackgroundColor #FAFAFA
    BorderColor #424242
    FontName sans-serif
    DiamondBackgroundColor #FFF3E0
    DiamondBorderColor #EF6C00
}

|Quản trị viên (Admin)|
start
:Đăng nhập & Truy cập Dashboard Quản trị Nội dung;

|Giao diện CMS (Frontend)|
:Hiển thị danh sách Học liệu\n(Mô hình 3D, Lý thuyết, Bài tập);

|Quản trị viên (Admin)|
:Chọn thao tác nghiệp vụ (CRUD);

if (Loại tác vụ?) then (Tạo/Cập nhật Mô hình 3D)
    :Nhập thông tin & Tải lên file mô hình (.glb/.gltf);
    |Giao diện CMS (Frontend)|
    :Gửi multipart/form-data Request;
    |Hệ thống API (Backend)|
    :Lưu trữ file an toàn & Trích xuất URL tài nguyên;

elseif (Soạn thảo Lý thuyết / Bài tập) then
    |Quản trị viên (Admin)|
    :Soạn thảo văn bản (Rich Text) & Cấu hình đáp án Quiz;
    |Giao diện CMS (Frontend)|
    :Gửi JSON payload (kèm ID Mô hình liên kết);
    |Hệ thống API (Backend)|
    :Kiểm tra toàn vẹn dữ liệu (Validation);

else (Đổi trạng thái / Xóa)
    |Quản trị viên (Admin)|
    :Bật/Tắt trạng thái (ACTIVE/INACTIVE) hoặc Xóa;
    |Giao diện CMS (Frontend)|
    :Gửi Request cập nhật trạng thái;
    |Hệ thống API (Backend)|
    :Xác thực đặc quyền Admin (JWT Check);
endif

|Hệ thống API (Backend)|
:Khởi tạo giao dịch (Transaction) & Thực thi truy vấn;

|Cơ sở dữ liệu (PostgreSQL)|
:Lưu trữ / Cập nhật bản ghi;
:Trả về trạng thái truy vấn;

|Hệ thống API (Backend)|
:Trả về kết quả cho máy khách (HTTP 200/201);

|Giao diện CMS (Frontend)|
:Hiển thị thông báo thành công (Toast/Alert);
:Tải lại danh sách hiển thị;

|Quản trị viên (Admin)|
:Hoàn tất quy trình;
stop
@enduml