@startuml
' Tùy chỉnh đường nét vuông góc, gọn gàng theo chuẩn UML Distilled
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 40
skinparam componentStyle rectangle

' Thiết lập bảng màu chuyên nghiệp, phân định ranh giới rõ ràng
skinparam package {
    BackgroundColor #FAFAFA
    BorderColor #757575
    FontColor #212121
    FontSize 14
    FontStyle bold
}
skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontName sans-serif
}
skinparam database {
    BackgroundColor #FFF3E0
    BorderColor #EF6C00
}
skinparam folder {
    BackgroundColor #F1F8E9
    BorderColor #2E7D32
}

' ==========================================
' ĐỊNH NGHĨA CÁC TẦNG KIẾN TRÚC
' ==========================================

package "1. Tầng Giao tiếp (Presentation Layer)" as L1 {
    component "Auth Middleware\n(Helmet, CORS, JWT)" as Mid
    component "RESTful Controllers\n(API Endpoints)" as Ctrl
    component "WebSocket Gateway\n(Realtime Connections)" as WS
    
    Mid -right-> Ctrl : "Xác thực \n & Chuyển tiếp"
}

package "2. Tầng Nghiệp vụ (Business Layer)" as L2 {
    component "Services Nghiệp vụ\n(User, Content, Exercise)" as BizSvc
    component "Services Sư phạm & Tương tác\n(Physics Engine, AI Logic)" as PhysSvc
}

package "3. Tầng Lưu trữ (Persistence Layer)" as L3 {
    component "Repositories\n(Data Access Layer)" as Repo
    component "Prisma Client\n(Type-safe ORM)" as ORM
    
    Repo -right-> ORM : "Sử dụng"
}

package "4. Tầng Dữ liệu (Data Storage Layer)" as L4 {
    database "PostgreSQL\n(Relational Database)" as DB
    folder "Asset Storage\n(/uploads 3D Models)" as Storage
}

' ==========================================
' ÉP LAYOUT XẾP CHỒNG THEO CHIỀU DỌC
' ==========================================
L1 -[hidden]down-> L2
L2 -[hidden]down-> L3
L3 -[hidden]down-> L4

' ==========================================
' ĐỊNH NGHĨA LUỒNG GIAO TIẾP (DATA FLOW)
' ==========================================
Ctrl -down-> BizSvc : " DTOs "
Ctrl -down-> PhysSvc : " DTOs "
WS -down-> PhysSvc : " Events "

BizSvc -down-> Repo : " Domain Models "
PhysSvc -down-> Repo : " Domain Models "

ORM -down-> DB : " SQL Queries / TCP "
Repo -down-> Storage : " File I/O "

@enduml