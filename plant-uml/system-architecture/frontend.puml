@startuml
' Tùy chỉnh đường nét vuông góc và khoảng cách rộng rãi hơn
skinparam linetype ortho
skinparam nodesep 90
skinparam ranksep 100
skinparam componentStyle rectangle
skinparam Padding 15

' Thiết lập bảng màu chuyên nghiệp
skinparam package {
    BackgroundColor #FAFAFA
    BorderColor #757575
    FontColor #212121
    FontSize 14
    FontStyle bold
}
skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontName sans-serif
}
skinparam actor {
    BackgroundColor #FFF3E0
    BorderColor #EF6C00
}
skinparam database {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

' ==========================================
' ĐỊNH NGHĨA CÁC THÀNH PHẦN
' ==========================================

actor "Người học\n(Student)" as User

package "Hệ thống Frontend (React SPA)" {

    package "1. Nền tảng & Điều hướng" {
        component "React Router\n(Điều phối luồng)" as Router
    }

    ' Sử dụng together để gom nhóm theo hàng ngang
    together {
        package "3. Hiển thị & Tương tác" as L3 {
            component "UI Components\n(Ant Design, Tailwind CSS)" as UI
        }
        package "4. Động cơ 3D" as L4 {
            component "3D Viewers (WebGL 2.0)\n(Three.js, React Three Fiber)" as Engine3D
        }
    }

    package "2. Trạng thái & Nghiệp vụ" as L2 {
        component "Context API & Hooks\n(Local/Auth State)" as LocalState
        component "TanStack Query\n(Server State & Cache)" as ServerState
        component "Axios Interceptors\n(HTTP Client)" as Axios
    }
}

database "Backend API\n(Node.js/Express)" as Backend

' ==========================================
' THIẾT LẬP BỐ CỤC LƯỚI (GRID LAYOUT)
' ==========================================
' Ép các thành phần vào đúng vị trí để các đường đi không bị chéo
User -[hidden]down- Router
UI -[hidden]right- Engine3D
LocalState -[hidden]right- ServerState
ServerState -[hidden]down- Axios

' ==========================================
' ĐỊNH NGHĨA GIAO TIẾP VÀ ĐIỀU HƯỚNG
' ==========================================
User -down-> UI : "Tương tác\n"
User -down-> Engine3D : "Thao tác 3D\n(Xoay/Zoom)"

Router -down--> UI : "Mount Component"
Router -down--> Engine3D : "Lazy Load\n(Facade Pattern)"

' ==========================================
' CHU TRÌNH RENDER CYCLE (STATE-DRIVEN UI)
' ==========================================
' Dùng \n để đẩy chữ ra xa đường nối, tránh đè vạch
UI -down--> LocalState : "1. Cập nhật State\n"
LocalState -up-> UI : "\n2a. Re-render UI"
LocalState -up-> Engine3D : "\n2b. Truyền Props (Vật lý)\n& Re-render 3D"

LocalState -right-> ServerState : "3. Invalidate Cache\n"
ServerState -down-> Axios : "4. Ủy quyền Fetch\n"

Axios -down-> Backend : "5. HTTP Request\n"
Backend -up-> Axios : "6. JSON Response"

Axios -up-> ServerState : "7. Cập nhật Bộ đệm\n"
ServerState -up-> UI : "8. Cập nhật dữ liệu View"

@enduml