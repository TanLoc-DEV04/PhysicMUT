@startuml
' Tùy chỉnh đường nét vuông góc, khoảng cách rộng rãi chống đè chữ
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 100
skinparam componentStyle rectangle
skinparam Padding 15

' Thiết lập bảng màu chuyên nghiệp (HBR / C4 Model Style)
skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #9E9E9E
    FontColor #212121
    FontSize 14
    FontStyle bold
}
skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontName sans-serif
}
skinparam database {
    BackgroundColor #FFF3E0
    BorderColor #EF6C00
    FontName sans-serif
}
skinparam node {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    FontName sans-serif
}

' ==========================================
' ĐỊNH NGHĨA CÁC THÀNH PHẦN KIẾN TRÚC
' ==========================================

component "Hệ thống Frontend\n(React, WebGL/Three.js)" as FE #FCE4EC

package "Phân hệ Bot AI (Python Microservice)" {
    component "Cổng Giao tiếp & Bảo mật\n(FastAPI, SlowAPI, Pydantic)" as API
    
    ' Gom nhóm Tool, RAG, DB nằm trên cùng một hàng ngang
    together {
        component "Cơ chế Gọi công cụ\n(Tool Calling Parser)" as Tool
        component "Động cơ Truy xuất RAG\n(LangChain, HF Embeddings)" as RAG
        database "Kho Tri thức Vector\n(ChromaDB)" as DB
    }
}

node "LLM Engine\n(Local Ollama)" as LLM

' ==========================================
' ÉP LAYOUT (LƯỚI BỐ CỤC ĐỂ CHỐNG LỘN XỘN)
' ==========================================
' Định hình trục dọc và ngang rõ ràng
FE -[hidden]down- API
API -[hidden]down- Tool
API -[hidden]down- RAG
Tool -[hidden]right- RAG
RAG -[hidden]down- DB
RAG -[hidden]down- LLM

' ==========================================
' ĐỊNH NGHĨA LUỒNG XỬ LÝ (KÉO DÀI MŨI TÊN & CHÈN \n)
' ==========================================

' Giao tiếp hai chiều FE <-> API
FE -down-> API : "1. Action\n(User gửi câu hỏi)\n"
API -up-> FE : "\n8. Response & Display\n(Phản hồi văn bản + Lệnh đổi tham số 3D)"

' Tách biệt 2 nhánh đi xuống RAG và đi lên từ Tool
API -down-> RAG : "2. Chuyển giao\n(Sau khi lọc Rate Limit & Prompt Guard)\n"
Tool -up-> API : "\n7. Bóc tách & Đóng gói"

' Giao tiếp hai chiều RAG <-> DB
RAG -right----> DB : "3. Nhúng (Embed) & Truy xuất\n"
DB -left----> RAG : "\n4. Trả về Top-K Context"

' Luồng vòng tròn xuống LLM và vòng lên Tool
RAG -right---> LLM : "5. Gửi Prompt\n(Context + History + Tool Schema)\n"
LLM -left---> Tool : "\n6. LLM suy luận\n(Sinh Text + JSON Function Calls)"

@enduml