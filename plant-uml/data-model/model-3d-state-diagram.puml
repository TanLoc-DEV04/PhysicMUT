@startuml
' Tùy chỉnh layout và font chữ chuẩn, tăng không gian để chống đè chữ
skinparam defaultFontName sans-serif
skinparam linetype ortho
skinparam nodesep 120
skinparam ranksep 100
skinparam Padding 15

' Định nghĩa bảng màu theo cấp độ bảo mật hiển thị (Visibility)
skinparam state {
    BackgroundColor<<Public>> #E8F5E9
    BorderColor<<Public>> #2E7D32
    
    BackgroundColor<<AdminOnly>> #FFF3E0
    BorderColor<<AdminOnly>> #EF6C00
    
    BackgroundColor<<Deleted>> #FFEBEE
    BorderColor<<Deleted>> #C62828
    
    ArrowColor #424242
}

title Biểu đồ Chuyển đổi Trạng thái (State Machine) - Thực thể Model3D

[*] -down-> DRAFT : Admin tạo mới\n

state "DRAFT (Đang soạn thảo)" as DRAFT <<AdminOnly>>
DRAFT : Quyền xem: Chỉ Admin
DRAFT : Trạng thái khởi tạo ban đầu

state "ACTIVE (Đã ban hành)" as ACTIVE <<Public>>
ACTIVE : Quyền xem: User & Admin
ACTIVE : Cho phép User tương tác 3D

state "INACTIVE (Tạm ẩn)" as INACTIVE <<AdminOnly>>
INACTIVE : Quyền xem: Chỉ Admin
INACTIVE : Tạm ngưng public để bảo trì

state "DELETED (Xóa mềm)" as DELETED <<Deleted>>
DELETED : Quyền xem: Chỉ Admin
DELETED : Gắn cờ deletedAt = DateTime

' ==========================================
' ĐỊNH NGHĨA CÁC LUỒNG CHUYỂN TRẠNG THÁI
' ==========================================

DRAFT -down-> ACTIVE : \n Admin "Activate"\n
' Giao tiếp 2 chiều ACTIVE <-> INACTIVE (Dùng \n để tách 2 luồng chữ)
ACTIVE -down-> INACTIVE : \n Admin "Deactivate"\n [Phát hiện lỗi, cần sửa đổi]
INACTIVE -up-> ACTIVE : \n Admin "Activate"\n [Đã sửa nội dung xong]

' Giao tiếp 2 chiều INACTIVE <-> DELETED (Dùng \n để đẩy xa nhau)
INACTIVE -left-> DELETED : Admin "Delete"
DELETED -left-> INACTIVE : Admin "Restore" \n [Gỡ cờ deletedAt]

' Xóa từ trạng thái ACTIVE
ACTIVE -right-> DELETED : Admin "Delete"

DELETED -down-> [*] : \n Hệ thống dọn dẹp\n (Archived / Xóa vĩnh viễn)

@enduml