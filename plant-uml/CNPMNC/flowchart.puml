@startuml
!pragma layout smetana
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam ArrowMessageAlignment center

title <size:18>Sơ đồ Dòng chảy: Cơ chế phòng vệ khi sự cố DDoS</size>\n<size:14><i>Hệ thống ngắt kết nối và chuyển hướng lưu hóa đơn cục bộ</i></size>\n

package "Ranh giới Cửa Hàng (Offline-first)" {
    component "<b>Máy tính tiền (POS)</b>\n(Duy trì bán thuốc OTC)" as pos #E2F0D9
    queue "<b>Local Message Queue</b>\n(Hàng đợi cục bộ)" as mq #FFF2CC
}

node "Hạ tầng Trung Tâm" as cloud {
    component "<color:#C00000><size:30><&fire></size></color>\n<b>Server Trung Tâm</b>\n(Tê liệt do DDoS)" as server #FCE4D6
}

' Luồng bị đứt gãy (Lao thẳng vào server đang cháy)
pos -[#red,dashed,thickness=3]-> server : "<color:red><size:20><&circle-x></size><b>Đứt mạng / Từ chối dịch vụ</b></color>"

' Luồng chuyển hướng an toàn (Uốn cong xuống Message Queue)
pos -[#0070C0,bold,thickness=4]-> mq : "<color:#0070C0><b> Chuyển hướng an toàn: </b></color> \n Lưu hóa đơn chờ đồng bộ"

' Điều hướng Layout
pos -[hidden]right-> server
pos -[hidden]down-> mq

note right of mq
  <b>Lợi ích:</b>
  - Dược sĩ vẫn tiếp tục bán hàng.
  - POS không bị "treo" chờ phản hồi.
  - Hóa đơn lưu an toàn không thất thoát.
end note

@enduml